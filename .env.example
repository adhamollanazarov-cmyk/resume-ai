APP_NAME=AI Resume & Cover Letter Generator
APP_VERSION=0.1.0
APP_ENV=development
FRONTEND_URL=https://your-vercel-domain.vercel.app
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-vercel-domain.vercel.app
ALLOW_VERCEL_PREVIEW_ORIGINS=false
INTERNAL_API_SECRET=change-me
USE_MOCK_AI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
APP_FRONTEND_URL=http://localhost:3000
MAX_RESUME_CHARS=12000
MAX_JOB_DESCRIPTION_CHARS=6000
MAX_PDF_SIZE_MB=5
FREE_ANALYSIS_LIMIT=3
RATE_LIMIT_ANALYZE=5/minute
AI_TIMEOUT_SECONDS=25
METRICS_TOKEN=
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/resume_ai
